---

---

<section id="contact" class="py-20 bg-base-100 neon-section">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-6">
        Parlons de <span class="text-gradient">Votre Projet</span>
      </h2>
      <p class="text-xl opacity-80">
        Remplissez ce formulaire et nous vous répondrons dans les 24h
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <div class="card bg-base-200 shadow-xl">
        <div class="card-body p-8">
          <form id="contact-form" class="space-y-6">
            <input type="hidden" name="access_key" value="4cfddd4e-902b-46f9-8634-75ab10366e71" />
            <input type="hidden" name="subject" value="Nouvelle demande depuis BKS Concept" />
            <input type="hidden" name="from_name" value="Site BKS Concept" />

            <input
              type="checkbox"
              name="botcheck"
              class="hidden"
              style="display: none;"
              tabindex="-1"
              autocomplete="off"
            />

            <div class="form-control">
              <label class="label">
                <span class="label-text text-lg">Votre nom complet *</span>
              </label>
              <input
                type="text"
                name="nom_complet"
                placeholder="John Doe"
                class="input input-bordered input-lg bg-base-100"
                required
              />
            </div>

            <div class="form-control">
              <label class="label">
                <span class="label-text text-lg">Votre email *</span>
              </label>
              <input
                type="email"
                name="email"
                placeholder="contact@entreprise.fr"
                class="input input-bordered input-lg bg-base-100"
                required
              />
            </div>

            <div class="form-control">
              <label class="label">
                <span class="label-text text-lg">Téléphone</span>
              </label>
              <input
                type="tel"
                name="telephone"
                placeholder="+32 4 84 24 36 46"
                class="input input-bordered input-lg bg-base-100"
              />
            </div>

            <div class="form-control">
              <label class="label">
                <span class="label-text text-lg">Type de projet *</span>
              </label>
              <select
                name="type_projet"
                class="select select-bordered select-lg bg-base-100"
                required
              >
                <option disabled selected value="">Choisissez une option</option>
                <option value="Site vitrine">Site web vitrine</option>
                <option value="E-commerce">Site e-commerce</option>
                <option value="Application web">Application web</option>
                <option value="Refonte">Refonte de site</option>
                <option value="Autre">Autre</option>
              </select>
            </div>

            <div class="form-control">
              <label class="label">
                <span class="label-text text-lg">Budget estimé *</span>
              </label>
              <select
                name="budget"
                class="select select-bordered select-lg bg-base-100"
                required
              >
                <option disabled selected value="">Choisissez une fourchette</option>
                <option value="Moins de 1000€">Moins de 1000€</option>
                <option value="1000-3000">1 000€ - 3 000€</option>
                <option value="3000-6000">3 000€ - 6 000€</option>
                <option value="6000-10000">6 000€ - 10 000€</option>
                <option value="10000-20000">10 000€ - 20 000€</option>
                <option value="20000+">20 000€+</option>
              </select>
            </div>

            <div class="form-control">
              <label class="label">
                <span class="label-text text-lg">Décrivez votre projet *</span>
              </label>
              <textarea
                name="message"
                class="textarea textarea-bordered textarea-lg bg-base-100 h-40"
                placeholder="Parlez-nous de votre projet, vos objectifs, vos délais..."
                required
              ></textarea>
            </div>

            <div class="form-control">
              <button type="submit" class="btn btn-primary btn-lg rounded-full mt-6">
                <span class="text-lg">Envoyer ma demande</span>
                <span class="ml-2">🚀</span>
              </button>
            </div>

            <div id="result" class="mt-4"></div>
          </form>
        </div>
      </div>

      <div>
        <div class="card bg-gradient-to-br from-primary/10 to-secondary/10 border border-primary/20 shadow-xl mb-8">
          <div class="card-body p-8">
            <h3 class="card-title text-2xl mb-6">📞 Contact rapide</h3>
            <div class="space-y-6">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-primary/20 rounded-full flex items-center justify-center">
                  <span class="text-primary text-xl">📧</span>
                </div>
                <div>
                  <p class="font-bold">Email</p>
                  <a href="mailto:contact@bksconcept.fr" class="link link-hover text-primary">
                    bksconcept@gmail.com
                  </a>
                </div>
              </div>

              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-primary/20 rounded-full flex items-center justify-center">
                  <span class="text-primary text-xl">📱</span>
                </div>
                <div>
                  <p class="font-bold">Téléphone</p>
                  <a href="tel:+32484243646" class="link link-hover text-primary">
                    +32 4 84 24 36 46
                  </a>
                </div>
              </div>

              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-primary/20 rounded-full flex items-center justify-center">
                  <span class="text-primary text-xl">📍</span>
                </div>
                <div>
                  <p class="font-bold">Adresse</p>
                  <p>Charleroi<br />Belgique</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="card bg-base-200 shadow-xl">
          <div class="card-body p-8">
            <h3 class="card-title text-2xl mb-6">❔ Questions fréquentes</h3>
            <div class="space-y-4">
              <div class="collapse collapse-plus bg-base-100">
                <input type="radio" name="faq" />
                <div class="collapse-title text-lg font-medium">
                  Quel est le délai moyen de création ?
                </div>
                <div class="collapse-content">
                  <p>Un site vitrine simple : 2-3 semaines. E-commerce : 4-6 semaines. Application web : sur devis.</p>
                </div>
              </div>

              <div class="collapse collapse-plus bg-base-100">
                <input type="radio" name="faq" />
                <div class="collapse-title text-lg font-medium">
                  Proposez-vous l'hébergement ?
                </div>
                <div class="collapse-content">
                  <p>Oui ! Nous offrons l'hébergement, la maintenance et le support technique.</p>
                </div>
              </div>

              <div class="collapse collapse-plus bg-base-100">
                <input type="radio" name="faq" />
                <div class="collapse-title text-lg font-medium">
                  Travaillez-vous à distance ?
                </div>
                <div class="collapse-content">
                  <p>Absolument ! Nous travaillons avec des clients partout en France et en Europe.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script is:inline>
      const form = document.getElementById("contact-form");
      const result = document.getElementById("result");

      form.addEventListener("submit", async function (e) {
        e.preventDefault();

        result.innerHTML = '<div class="alert alert-info"><span>Envoi en cours...</span></div>';

        const formData = new FormData(form);
        const object = Object.fromEntries(formData);
        const json = JSON.stringify(object);

        try {
          const response = await fetch("https://api.web3forms.com/submit", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              Accept: "application/json"
            },
            body: json
          });

          const data = await response.json();

          if (response.ok) {
            window.location.href = "/success";
          } else {
            result.innerHTML = `
              <div class="alert alert-error">
                <span>${data.message || "Une erreur est survenue."}</span>
              </div>
            `;
          }
        } catch (error) {
          result.innerHTML = `
            <div class="alert alert-error">
              <span>❌ Impossible d'envoyer le message. Veuillez réessayer.</span>
            </div>
          `;
        }
      });
    </script>
  </div>
</section>

<style>
  .text-gradient {
    background: linear-gradient(90deg, #3B82F6, #8B5CF6, #EC4899);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>