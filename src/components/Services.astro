---
const services = [
  {
    title: "Site Web Vitrine",
    description: "Présentez votre entreprise avec un site moderne, rassurant et structuré pour mettre en valeur vos services et générer des demandes de contact.",
    icon: "🎨",
    features: ["Design sur mesure", "Responsive design", "Base SEO", "Mise en ligne"]
  },
  {
    title: "Site E-commerce",
    description: "Vendez vos produits en ligne avec une boutique claire, fluide et pensée pour rassurer l’utilisateur à chaque étape du parcours d’achat.",
    icon: "🛒",
    features: ["Paiement sécurisé", "Catalogue produits", "Parcours de commande", "Mobile-first"]
  },
  {
    title: "Application Web",
    description: "Développement d’outils et plateformes sur mesure pour répondre à des besoins spécifiques et gagner en efficacité.",
    icon: "⚡",
    features: ["Développement sur mesure", "Base de données", "API", "Maintenance possible"]
  },
  {
    title: "Refonte de Site",
    description: "Modernisez un site existant pour améliorer son image, son ergonomie, sa vitesse et sa capacité à convertir.",
    icon: "🔄",
    features: ["Audit", "Modernisation UI/UX", "Optimisation SEO", "Migration"]
  }
];
---

<section id="services" class="py-20 bg-base-200 neon-section">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-6">
        Nos Services <span class="text-primary">Web</span>
      </h2>
      <p class="text-lg md:text-xl opacity-80">
        Des prestations pensées pour améliorer votre image, clarifier votre offre et renforcer votre présence en ligne.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {services.map((service) => (
        <article class="card bg-base-100 shadow-xl card-3d group hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 h-full">
          <div class="card-body p-8 flex flex-col h-full">
            <div class="text-5xl mb-4 transform group-hover:scale-110 transition-transform duration-300">
              {service.icon}
            </div>

            <h3 class="card-title text-2xl mb-4">{service.title}</h3>

            <p class="opacity-80 mb-6">
              {service.description}
            </p>

            <ul class="space-y-2 mb-6">
              {service.features.map((feature) => (
                <li class="flex items-center">
                  <div class="w-2 h-2 bg-primary rounded-full mr-3"></div>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>

            <div class="card-actions mt-auto">
              <a href="/services" class="btn btn-ghost text-primary group-hover:underline">
                En savoir plus →
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="text-center mt-10">
      <a href="/contact" class="btn btn-outline btn-lg rounded-full px-10 text-lg border-2">
        Discuter de mon projet
      </a>
    </div>
  </div>
</section>