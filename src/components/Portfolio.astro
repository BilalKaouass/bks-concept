---
const projects = [
  {
    title: "Autosoftronics",
    category: "Site vitrine",
    description:
      "Création d’un site professionnel pour un spécialiste en électronique automobile, avec une présentation claire des services, une structure rassurante et une prise de contact simplifiée.",
    image: "/images/projects/autosoftronics.jpg",
    tags: ["Astro", "Tailwind", "SEO", "UX"],
    features: [
      "Présentation claire des services",
      "Parcours orienté devis",
      "Structure premium et rassurante"
    ],
    link: "https://autosoftronics.com"
  },
  {
    title: "Greenfarmerz",
    category: "Site vitrine",
    description:
      "Réalisation d’un site orienté conversion pour une entreprise active dans les solutions énergétiques, avec mise en avant des prestations et de la prise de contact.",
    image: "/images/projects/greenfarmerz.jpg",
    tags: ["Web Design", "UX", "Responsive", "Conversion"],
    features: [
      "Mise en avant des solutions proposées",
      "Interface claire et responsive",
      "Navigation pensée pour la demande de devis"
    ],
    link: "https://www.greenfarmerz.eu"
  }
];
---

<section id="portfolio" class="py-24 bg-base-100">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">
        Nos <span class="text-gradient">Réalisations</span>
      </h2>

      <p class="text-lg md:text-xl text-base-content/70 leading-relaxed">
        Des projets conçus pour valoriser l’image de marque, clarifier l’offre et faciliter la conversion.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-14">
      {projects.map((project) => (
        <article class="group rounded-[28px] overflow-hidden border border-base-300/60 bg-base-200 shadow-[0_10px_40px_rgba(0,0,0,0.12)] hover:shadow-[0_20px_60px_rgba(0,0,0,0.18)] transition-all duration-500 hover:-translate-y-1 flex flex-col h-full">
          <div class="relative h-64 md:h-80 overflow-hidden">
            <img
              src={project.image}
              alt={`Projet web ${project.title}`}
              class="w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-700"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[#020817]/70 via-transparent to-transparent"></div>

            <div class="absolute top-5 left-5">
              <span class="inline-flex items-center rounded-full border border-white/15 bg-white/10 backdrop-blur-md px-4 py-2 text-xs md:text-sm font-medium text-white">
                {project.category}
              </span>
            </div>

            <div class="absolute bottom-5 left-5 right-5">
              <h3 class="text-2xl md:text-3xl font-bold text-white drop-shadow-md">
                {project.title}
              </h3>
            </div>
          </div>

          <div class="p-7 md:p-8 flex flex-col flex-1">
            <p class="text-base md:text-lg text-base-content/72 leading-relaxed mb-6">
              {project.description}
            </p>

            <div class="flex flex-wrap gap-2 mb-6">
              {project.tags.map((tag) => (
                <span class="badge badge-outline border-base-300/80 px-3 py-3 text-xs md:text-sm">
                  {tag}
                </span>
              ))}
            </div>

            <div class="space-y-3 mb-8">
              {project.features.map((feature) => (
                <div class="flex items-start gap-3 text-sm md:text-base text-base-content/78">
                  <span class="mt-2 w-2 h-2 rounded-full bg-primary shrink-0"></span>
                  <span>{feature}</span>
                </div>
              ))}
            </div>

            <div class="mt-auto flex items-end justify-between gap-4 pt-6 border-t border-base-300/60">
              <div class="flex flex-col justify-center">
                <div class="text-xs uppercase tracking-[0.18em] text-base-content/45">
                  Projet en ligne
                </div>
                <div class="text-sm md:text-base font-medium text-base-content mt-1">
                  {project.title}
                </div>
              </div>

              <a
                href={project.link}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-primary rounded-2xl px-6 min-h-[56px] group/btn inline-flex items-center"
              >
                Voir le site
                <span class="ml-2 transition-transform duration-300 group-hover/btn:translate-x-1">→</span>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="rounded-[28px] border border-base-300/60 bg-base-200 px-8 py-10 md:px-12 md:py-12 text-center shadow-[0_10px_40px_rgba(0,0,0,0.08)]">
      <h3 class="text-2xl md:text-3xl font-bold mb-4">
        Votre projet peut être le prochain.
      </h3>

      <p class="text-base md:text-lg text-base-content/70 max-w-2xl mx-auto mb-8 leading-relaxed">
        Vous souhaitez créer un site plus moderne, plus crédible et plus efficace pour votre activité ? Parlons de votre besoin.
      </p>

      <a
        href="/contact"
        class="btn btn-outline btn-lg rounded-2xl px-8 text-base md:text-lg"
      >
        Discuter de votre projet
      </a>
    </div>
  </div>
</section>

<style>
  .text-gradient {
    background: linear-gradient(90deg, #60A5FA, #8B5CF6, #EC4899);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>