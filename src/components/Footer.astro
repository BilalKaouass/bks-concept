---
const currentYear = new Date().getFullYear();
---

<footer class="footer footer-center bg-base-200 text-base-content p-10 border-t border-base-300">
  <div class="container mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <div class="text-center md:text-left">
        <a class="btn btn-ghost text-2xl mb-4" href="/">
          <span class="font-bold text-primary">BKS</span>
          <span class="font-light">Concept</span>
        </a>
        <p class="opacity-80">
          Création de sites web professionnels à Charleroi, en Belgique et à distance.
        </p>
      </div>

      <div>
        <h3 class="footer-title mb-4">Navigation</h3>
        <div class="flex flex-col gap-2">
          <a href="/" class="link link-hover hover:text-primary">Accueil</a>
          <a href="/services" class="link link-hover hover:text-primary">Services</a>
          <a href="/portfolio" class="link link-hover hover:text-primary">Portfolio</a>
          <a href="/about" class="link link-hover hover:text-primary">À propos</a>
          <a href="/contact" class="link link-hover hover:text-primary">Contact</a>
        </div>
      </div>

      <div>
        <h3 class="footer-title mb-4">Services</h3>
        <div class="flex flex-col gap-2">
          <a href="/services" class="link link-hover hover:text-primary">Site vitrine</a>
          <a href="/services" class="link link-hover hover:text-primary">E-commerce</a>
          <a href="/services" class="link link-hover hover:text-primary">Application web</a>
          <a href="/services" class="link link-hover hover:text-primary">Refonte de site</a>
          <a href="/services" class="link link-hover hover:text-primary">SEO de base</a>
        </div>
      </div>

      <div>
        <h3 class="footer-title mb-4">Contact</h3>
        <div class="flex flex-col gap-3">
          <div>
            <p class="font-medium">Email</p>
            <a href="mailto:bksconcept@gmail.com" class="text-sm opacity-80 link link-hover">bksconcept@gmail.com</a>
          </div>
          <div>
            <p class="font-medium">Téléphone</p>
            <a href="tel:+32484243646" class="text-sm opacity-80 link link-hover">+32 4 84 24 36 46</a>
          </div>
          <div>
            <p class="font-medium">Localisation</p>
            <p class="text-sm opacity-80">Charleroi, Belgique</p>
          </div>
        </div>
      </div>
    </div>

    <div class="divider my-10"></div>

    <div class="flex flex-col md:flex-row justify-between items-center w-full gap-4">
      <div>
        <p>© {currentYear} BKS Concept. Tous droits réservés.</p>
      </div>
      <div class="flex gap-6 mt-4 md:mt-0">
        <a href="/mentions-legales" class="link link-hover text-sm">Mentions légales</a>
<a href="/politique-confidentialite" class="link link-hover text-sm">Politique de confidentialité</a>
      </div>
    </div>

    <div class="mt-8">
      <button id="back-to-top" class="btn btn-circle btn-primary" aria-label="Retour en haut">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
        </svg>
      </button>
    </div>
  </div>
</footer>

<script>
  document.getElementById('back-to-top')?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>