---
const testimonials = [
  {
    name: "Marie Laurent",
    role: "CEO - Fashion Luxe",
    content: "Notre site e-commerce créé par BKS Concept a multiplié nos ventes par 3. L'expérience utilisateur est exceptionnelle !",
    rating: 5,
    image: "ML"
  },
  {
    name: "Thomas Dubois",
    role: "Directeur - Tech Startup",
    content: "L'application web qu'ils ont développée pour nous a révolutionné notre productivité. Service client au top !",
    rating: 5,
    image: "TD"
  },
  {
    name: "Sophie Martin",
    role: "Restauratrice - Le Gourmet",
    content: "Notre site vitrine attire maintenant 70% de clients en plus. Le design fait vraiment WAOW comme promis !",
    rating: 5,
    image: "SM"
  },
  {
    name: "Alexandre Chen",
    role: "Founder - EduTech Pro",
    content: "Plateforme e-learning performante et intuitive. Les retours de nos étudiants sont excellents.",
    rating: 5,
    image: "AC"
  },
  {
    name: "Camille Petit",
    role: "Manager - Immo Elite",
    content: "Le site avec visite virtuelle a totalement transformé notre business. Conversion +200% !",
    rating: 5,
    image: "CP"
  },
  {
    name: "Lucas Moreau",
    role: "CEO - FitLife App",
    content: "Application mobile innovante livrée dans les délais. L'équipe est réactive et professionnelle.",
    rating: 5,
    image: "LM"
  }
];

const marqueeTestimonials = [...testimonials, ...testimonials];
---

<section id="testimonials" class="relative py-24 bg-base-200 neon-section">
  <div class="container mx-auto px-4 relative z-10">
    <div class="text-center max-w-4xl mx-auto mb-16">
      <h2 class="text-5xl md:text-6xl lg:text-7xl font-black leading-[0.95] mb-6 text-base-content">
        Ils Nous Font <span class="text-gradient">Confiance</span>
      </h2>

      <p class="text-lg md:text-xl text-base-content/70 max-w-2xl mx-auto">
        Découvrez ce que nos clients disent de leur expérience
      </p>
    </div>
  </div>

  <!-- Défilement -->
  <div class="relative z-10 marquee-wrapper">
    <div class="marquee-track">
      {marqueeTestimonials.map((testimonial) => (
        <article class="testimonial-card">
          <div class="flex gap-1 mb-4">
            {Array.from({ length: testimonial.rating }).map(() => (
              <span class="text-yellow-400 text-lg">★</span>
            ))}
          </div>

          <p class="text-base-content/85 text-base leading-relaxed mb-6 min-h-[120px]">
            "{testimonial.content}"
          </p>

          <div class="flex items-center gap-4">
            <div class="testimonial-avatar">
              <span>{testimonial.image}</span>
            </div>

            <div>
              <h3 class="text-base-content font-bold text-lg leading-tight">
                {testimonial.name}
              </h3>
              <p class="text-base-content/60 text-sm mt-1">
                {testimonial.role}
              </p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .text-gradient {
    background: linear-gradient(90deg, #3B82F6, #8B5CF6, #EC4899);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .marquee-wrapper {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
    padding-block: 8px;
  }

  .marquee-track {
    display: flex;
    gap: 1.25rem;
    width: max-content;
    animation: marqueeScroll 40s linear infinite;
    padding: 0 1rem;
  }

  .marquee-wrapper:hover .marquee-track {
    animation-play-state: paused;
  }

  .testimonial-card {
    width: 360px;
    min-width: 360px;
    border-radius: 24px;
    padding: 1.5rem;
    background: linear-gradient(135deg, rgba(10, 18, 40, 0.94), rgba(8, 14, 30, 0.94));
    border: 1px solid rgba(96, 165, 250, 0.14);
    box-shadow:
      0 10px 30px rgba(0, 0, 0, 0.22),
      inset 0 1px 0 rgba(255,255,255,0.04);
    transition: box-shadow 0.35s ease, border-color 0.35s ease, transform 0.35s ease;
    backdrop-filter: blur(10px);
  }

  .testimonial-card:hover {
    border-color: rgba(167, 139, 250, 0.24);
    box-shadow:
      0 16px 40px rgba(0, 0, 0, 0.28),
      0 0 24px rgba(96, 165, 250, 0.06);
    transform: scale(1.01);
  }

  .testimonial-avatar {
    width: 52px;
    height: 52px;
    border-radius: 9999px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 1.2rem;
    color: #0b1220;
    background: linear-gradient(135deg, #ec4899 0%, #a855f7 40%, #60a5fa 75%, #67e8f9 100%);
    flex-shrink: 0;
  }

  @keyframes marqueeScroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(calc(-50% - 0.625rem));
    }
  }

  @media (max-width: 1024px) {
    .testimonial-card {
      width: 320px;
      min-width: 320px;
    }
  }

  @media (max-width: 768px) {
    .marquee-track {
      gap: 1rem;
      animation-duration: 34s;
    }

    .testimonial-card {
      width: 280px;
      min-width: 280px;
      padding: 1.25rem;
    }

    .testimonial-card p {
      min-height: auto;
    }
  }
</style>