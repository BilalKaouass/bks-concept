---
import Layout from '../layouts/Layout.astro';
import ContactComponent from '../components/Contact.astro';
import CTA from '../components/CTA.astro';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Accueil',
      item: 'https://bksconcept.netlify.app/'
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Contact',
      item: 'https://bksconcept.netlify.app/contact'
    }
  ]
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Quel est le délai moyen de création ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Un site vitrine simple peut être livré en 2 à 3 semaines. Un e-commerce demande généralement 4 à 6 semaines. Pour une application web, le délai dépend du périmètre fonctionnel.'
      }
    },
    {
      '@type': 'Question',
      name: 'Proposez-vous l’hébergement et la maintenance ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Oui, nous pouvons accompagner nos clients sur l’hébergement, la maintenance technique, les mises à jour et le suivi après mise en ligne.'
      }
    },
    {
      '@type': 'Question',
      name: 'Travaillez-vous à distance ?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Oui. BKS Concept travaille à Charleroi, partout en Belgique, en France et à distance selon la nature du projet.'
      }
    }
  ]
};
---

<Layout
  title="Contact | Demander un devis pour votre site web | BKS Concept"
  description="Contactez BKS Concept pour la création de votre site vitrine, e-commerce, application web ou refonte de site. Réponse sous 24h, devis gratuit, basé à Charleroi."
  canonical="https://bksconcept.netlify.app/contact"
  schema={[breadcrumbSchema, faqSchema]}
>
  <section class="hero min-h-[50vh] bg-gradient-to-br from-primary/10 to-secondary/10">
    <div class="hero-content text-center">
      <div class="max-w-4xl">
        <h1 class="text-5xl md:text-6xl font-bold mb-6">
          Contactez <span class="text-gradient">BKS Concept</span>
        </h1>
        <p class="text-xl md:text-2xl opacity-80 mb-10 max-w-3xl mx-auto">
          Discutons de votre projet web. Réponse rapide, devis gratuit et accompagnement personnalisé.
        </p>
        <div class="stats stats-vertical lg:stats-horizontal shadow bg-base-100 w-full max-w-3xl mx-auto">
          <div class="stat">
            <div class="stat-title text-sm md:text-base">Temps de réponse</div>
            <div class="stat-value text-primary text-xl sm:text-2xl md:text-3xl">24h</div>
            <div class="stat-desc text-xs sm:text-sm">En moyenne</div>
          </div>

          <div class="stat">
            <div class="stat-title text-sm md:text-base">Support</div>
            <div class="stat-value text-secondary text-xl sm:text-2xl md:text-3xl">7j/7</div>
            <div class="stat-desc text-xs sm:text-sm">Selon le projet</div>
          </div>

          <div class="stat">
            <div class="stat-title text-sm md:text-base">Devis</div>
            <div class="stat-value text-accent text-xl sm:text-2xl md:text-3xl">Gratuit</div>
            <div class="stat-desc text-xs sm:text-sm">Sans engagement</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">
        Parlez-nous de votre projet digital
      </h2>
      <p class="text-lg opacity-80 mb-4">
        Vous cherchez un partenaire pour créer un site vitrine, une boutique en ligne, une application web ou moderniser un site existant ?
        BKS Concept vous accompagne avec une approche claire, humaine et orientée résultats.
      </p>
      <p class="text-lg opacity-80">
        Basé à Charleroi, nous travaillons avec des clients en Belgique, en France et à distance.
      </p>
    </div>
  </section>

  <ContactComponent />
  <CTA />
</Layout>

<style>
  .text-gradient {
    background: linear-gradient(90deg, #3B82F6, #8B5CF6, #EC4899);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>